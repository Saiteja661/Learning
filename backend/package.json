{
  "name": "expense-tracker-backend",
  "version": "0.1.0",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/start.js",
    "dev": "nodemon src/index.js",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=src/prisma/schema.prisma",
    "db:push": "prisma db push --schema=src/prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema=src/prisma/schema.prisma --name init",
    "test": "jest --runInBand"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "nodemon": "^3.1.10"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^6.0.1",
    "jsonwebtoken": "^9.0.0",
    "prisma": "^5.0.0"
  }
}
